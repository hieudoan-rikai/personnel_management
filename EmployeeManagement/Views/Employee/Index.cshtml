@model IEnumerable<EmployeeManagement.Models.Employee>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Quản lý đăng ký nhân viên</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="~/Content/employee.css" />
</head>
<body class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>社員登録 - QUẢN LÝ ĐĂNG KÝ NHÂN VIÊN</h2>
        <div>
            <button class="btn btn-primary" id="btnAddNew">Thêm mới nhân viên</button>
            <a href="@Url.Action("ExportExcel", "Employee")" class="btn btn-success">Xuất báo cáo Excel</a>
        </div>
    </div>

    <div id="serverMessage"></div>

    <table class="table table-bordered table-striped" id="employeeTable">
        <thead class="thead-dark">
            <tr>
                <th>Mã NV</th>
                <th>Họ Tên</th>
                <th>Phòng Ban</th>
                <th>Ngày Sinh</th>
                <th class="text-center" style="width: 180px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr data-id="@item.Id">
                    <td class="emp-code">@item.EmployeeCode</td>
                    <td class="emp-fullname">@item.FullName</td>
                    <td class="emp-department">@item.Department</td>
                    <td class="emp-birthdate">@item.DateOfBirth.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center align-items-center style-buttons-row">
                            <button class="btn btn-sm btn-warning btn-edit mr-2" data-id="@item.Id"><i class="fas fa-edit"></i> Sửa</button>
                            <button class="btn btn-sm btn-danger btn-delete" data-id="@item.Id"><i class="fas fa-trash"></i> Xóa</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="modal fade" id="employeeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Đăng ký nhân viên mới</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="employeeForm">
                        <input type="hidden" id="txtId" value="0" />

                        <div class="form-group">
                            <label>Mã Nhân Viên</label>
                            <input type="text" id="txtEmpCode" class="form-control" />
                            <small id="errorEmployeeCode" class="text-danger"></small>
                        </div>
                        <div class="form-group">
                            <label>Họ và Tên</label>
                            <input type="text" id="txtFullName" class="form-control" />
                            <small id="errorFullName" class="text-danger"></small>
                        </div>
                        <div class="form-group">
                            <label>Phòng Ban</label>
                            <input type="text" id="txtDepartment" class="form-control" />
                            <small id="errorDepartment" class="text-danger"></small>
                        </div>
                        <div class="form-group">
                            <label>Ngày Sinh</label>
                            <input type="date" id="txtBirthDate" class="form-control" max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <small id="errorDateOfBirth" class="text-danger"></small>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>
                    <button type="button" class="btn btn-primary" id="btnSaveEmployee">Lưu lại</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Xác nhận xóa</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body fs-5">
                    Bạn có chắc chắn muốn xóa nhân viên này khỏi hệ thống không? Hành động này không thể hoàn tác.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy bỏ</button>
                    <button type="button" class="btn btn-danger" id="btnConfirmDeleteExecute">Đồng ý xóa</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/employee.js"></script>
</body>
</html>